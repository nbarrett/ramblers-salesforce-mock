{
  "name": "ramblers-salesforce-mock",
  "version": "0.2.0",
  "private": true,
  "description": "Standalone reference mock server for the Ramblers Salesforce API (nbarrett/ngx-ramblers#209). Shared dev fixture for NGX, MailMan and HQ.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build:server": "esbuild src/server.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/server.js --packages=external --sourcemap",
    "build:client": "vite build",
    "build:release-notes": "tsx scripts/build-release-notes.ts",
    "build": "pnpm run build:server && pnpm run build:client",
    "predeploy": "pnpm run build:release-notes",
    "deploy": "flyctl deploy",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' 'scripts/**/*.ts'",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "setup:hooks": "bash tools/setup-git-hooks.sh"
  },
  "dependencies": {
    "@ramblers/sf-contract": "github:nbarrett/ramblers-salesforce-contract",
    "bcryptjs": "2.4.3",
    "cookie-parser": "1.4.7",
    "csrf-sync": "4.2.1",
    "exceljs": "4.4.0",
    "express": "4.22.1",
    "express-session": "1.19.0",
    "mongoose": "8.23.0",
    "multer": "2.1.1",
    "pino": "9.14.0",
    "pino-http": "10.5.0",
    "swagger-ui-express": "5.0.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "4.17.25",
    "@types/express-session": "1.19.0",
    "@types/multer": "1.4.13",
    "@types/node": "20.19.39",
    "@types/supertest": "6.0.3",
    "@types/swagger-ui-express": "4.1.8",
    "esbuild": "0.28.0",
    "eslint": "9.39.4",
    "jiti": "2.6.0",
    "supertest": "7.2.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.1",
    "vite": "8.0.10",
    "vitest": "2.1.9"
  }
}
