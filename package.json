{
  "name": "ramblers-salesforce-mock",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone reference mock server for the Ramblers Salesforce API (nbarrett/ngx-ramblers#209). Shared dev fixture for NGX, MailMan and HQ.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build:server": "esbuild src/server.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/server.js --packages=external --sourcemap",
    "build:client": "esbuild src/admin/client/index.ts --bundle --target=es2022 --format=iife --outfile=public/admin.js --sourcemap --minify",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' 'scripts/**/*.ts'",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "check:schema-drift": "tsx scripts/check-schema-drift.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "csrf-sync": "^4.0.3",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "mongoose": "^8.8.0",
    "multer": "^2.1.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.1",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.17.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.7",
    "@typescript-eslint/eslint-plugin": "^8.12.0",
    "@typescript-eslint/parser": "^8.12.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.14.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
