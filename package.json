{
  "name": "ramblers-salesforce-mock",
  "version": "0.2.0",
  "private": true,
  "description": "Standalone reference mock server for the Ramblers Salesforce API (nbarrett/ngx-ramblers#209). Shared dev fixture for NGX, MailMan and HQ.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build:server": "esbuild src/server.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/server.js --packages=external --sourcemap",
    "build:client": "esbuild src/admin/client/index.ts --bundle --target=es2022 --format=iife --outfile=public/admin.js --sourcemap --minify",
    "build:release-notes": "tsx scripts/build-release-notes.ts",
    "build": "npm run build:server && npm run build:client",
    "predeploy": "npm run build:release-notes",
    "deploy": "flyctl deploy",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' 'scripts/**/*.ts'",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "check:schema-drift": "tsx scripts/check-schema-drift.ts",
    "setup:hooks": "bash tools/setup-git-hooks.sh"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "cookie-parser": "1.4.7",
    "csrf-sync": "4.2.1",
    "exceljs": "4.4.0",
    "express": "4.22.1",
    "express-session": "1.19.0",
    "mongoose": "8.23.0",
    "multer": "2.1.1",
    "pino": "9.14.0",
    "pino-http": "10.5.0",
    "swagger-ui-express": "5.0.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "4.17.25",
    "@types/express-session": "1.19.0",
    "@types/multer": "1.4.13",
    "@types/node": "20.19.39",
    "@types/supertest": "6.0.3",
    "@types/swagger-ui-express": "4.1.8",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "esbuild": "0.24.2",
    "eslint": "9.39.4",
    "supertest": "7.2.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  }
}
